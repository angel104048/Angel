#include <Wire.h>
#include <SPI.h>
#include <SD.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BMP3XX.h>
#include <Adafruit_LSM9DS1.h>
#include <TinyGPS++.h>
#include "SparkFunLSM6DS3.h"
#include <LoRa.h> 

// ===== 引腳定義 (保持不變) =====
#define SD_CS     15
#define SD_SCK    14
#define SD_MISO   12
#define SD_MOSI   13
#define LORA_CS      2
#define LORA_RST     0
#define LORA_DIO0    35
#define RXD2 4
#define TXD2 5

Adafruit_BMP3XX bmp;
LSM6DS3 lsm6(I2C_MODE, 0x6A);      
Adafruit_LSM9DS1 lsm9 = Adafruit_LSM9DS1(); 
TinyGPSPlus gps;
HardwareSerial neogps(2);
File dataFile;

const char* filename = "/super_blackbox.csv";

void setup() {
  Serial.begin(115200);
  delay(2000); 

  pinMode(SD_CS, OUTPUT);
  pinMode(LORA_CS, OUTPUT);
  digitalWrite(SD_CS, HIGH);
  digitalWrite(LORA_CS, HIGH);

  Serial.println("\n--- 火箭端：3D 姿態同步版 ---");

  Wire.begin(8, 9);
  neogps.begin(38400, SERIAL_8N1, RXD2, TXD2);

  if (!bmp.begin_I2C()) Serial.println("⚠️ BMP390 失敗");
  if (lsm6.begin() != 0) Serial.println("⚠️ LSM6DS3 失敗");
  if (!lsm9.begin()) Serial.println("⚠️ LSM9DS1 失敗");
  else lsm9.setupMag(lsm9.LSM9DS1_MAGGAIN_4GAUSS);

  SPI.begin(SD_SCK, SD_MISO, SD_MOSI, SD_CS);
  if (!SD.begin(SD_CS, SPI, 1000000)) {
    Serial.println("❌ SD 失敗");
  } else {
    if (!SD.exists(filename)) {
      dataFile = SD.open(filename, FILE_WRITE);
      if (dataFile) {
        dataFile.println("Time_ms,Lat,Lng,Alt_m,Sats,Temp_C,Press_hPa,AccX,AccY,AccZ,GyroX,GyroY,GyroZ,MagX,MagY,MagZ");
        dataFile.close();
      }
    }
    Serial.println("✅ SD 準備就緒");
  }

  LoRa.setPins(LORA_CS, LORA_RST, LORA_DIO0);
  if (!LoRa.begin(433E6)) {
    Serial.println("❌ LoRa 失敗");
  } else {
    LoRa.setTxPower(17);
    Serial.println("✅ LoRa 成功");
  }
}

void loop() {
  while (neogps.available() > 0) gps.encode(neogps.read());

  static unsigned long lastLog = 0;
  if (millis() - lastLog >= 500) { // 提高到每秒 2 次更新，畫面比較順
    lastLog = millis();
    logAndDisplayAllData();
  }
}

void logAndDisplayAllData() {
  // --- 1. 讀取數據 ---
  bmp.performReading();
  float ax = lsm6.readFloatAccelX();
  float ay = lsm6.readFloatAccelY();
  float az = lsm6.readFloatAccelZ();
  float gx = lsm6.readFloatGyroX();
  float gy = lsm6.readFloatGyroY();
  float gz = lsm6.readFloatGyroZ();
  sensors_event_t a, m, g, t;
  lsm9.getEvent(&a, &m, &g, &t);

  // --- 2. 核心計算：計算姿態角 (Pitch & Roll) ---
  // 使用 atan2 根據重力加速度算出傾斜角度
  float pitch_deg = atan2(-ax, sqrt(ay * ay + az * az)) * 57.3;
  float roll_deg  = atan2(ay, az) * 57.3;

  // 建立 Processing 專用通訊協定：P,角度,R,角度,Y,角度
  String visualData = "P," + String(pitch_deg, 1) + ",R," + String(roll_deg, 1) + ",Y,0";

  // --- 3. 步驟 A：SD 卡寫入 (保持原本格式) ---
  digitalWrite(LORA_CS, HIGH); 
  delay(10);
  digitalWrite(SD_CS, LOW);    
  
  dataFile = SD.open(filename, FILE_APPEND);
  if (dataFile) {
    dataFile.print(millis()); dataFile.print(",");
    dataFile.print(gps.location.lat(), 6); dataFile.print(",");
    dataFile.print(gps.location.lng(), 6); dataFile.print(",");
    dataFile.print(gps.altitude.meters(), 1); dataFile.print(",");
    dataFile.print(gps.satellites.value()); dataFile.print(",");
    dataFile.print(bmp.temperature, 2); dataFile.print(",");
    dataFile.print(bmp.pressure / 100.0, 2); dataFile.print(",");
    dataFile.print(ax, 4); dataFile.print(",");
    dataFile.print(ay, 4); dataFile.print(",");
    dataFile.print(az, 4); dataFile.print(",");
    dataFile.print(gx, 4); dataFile.print(",");
    dataFile.print(gy, 4); dataFile.print(",");
    dataFile.print(gz, 4); dataFile.print(",");
    dataFile.print(m.magnetic.x, 4); dataFile.print(",");
    dataFile.print(m.magnetic.y, 4); dataFile.println(m.magnetic.z, 4);
    dataFile.close();
    Serial.print("💾 SD OK | ");
  } else {
    Serial.print("💾 SD FAIL | ");
    SD.begin(SD_CS, SPI, 1000000); 
  }
  digitalWrite(SD_CS, HIGH);

  delay(50); // 縮短緩衝

  // --- 4. 步驟 B：LoRa 發射 (發射姿態數據) ---
  digitalWrite(SD_CS, HIGH);
  delay(10);
  digitalWrite(LORA_CS, LOW);
  
  if (LoRa.beginPacket()) {
    LoRa.print(visualData); 
    LoRa.endPacket();
    Serial.println("📡 LoRa TX: " + visualData);
  } else {
    Serial.println("📡 LoRa BUSY");
  }
  digitalWrite(LORA_CS, HIGH);
}
